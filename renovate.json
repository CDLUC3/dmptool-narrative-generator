{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "enabledManagers": [
    "npm",
    "nvm",
    "docker-compose",
    "dockerfile"
  ],
  "baseBranches": [
    "development"
  ],
  "rebaseWhen": "behind-base-branch",
  "ignorePaths": [
    ".github",
    ".husky",
    "coverage/**",
    "docs/**"
  ],
  "minimumReleaseAge": "3 days",
  "abandonmentThreshold": "2 years",
  "bumpVersion": "minor",
  "schedule": [
    "* 0-2 * * 0,3"
  ]
}
